# ──────────────────────────────────────────────
#  ETIP — Environment Variables Template
#  Copy to .env and fill in real values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Django ─────────────────────────────────────
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database (PostgreSQL) ───────────────────────
DB_NAME=etip_db
DB_USER=etip_user
DB_PASSWORD=etip_password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ─────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ── Payment Gateways ────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_BASE_URL=https://api.paystack.co

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_HASH=your_flutterwave_webhook_hash

# ── DISCO APIs ──────────────────────────────────
DISCO_IBEDC_API_URL=https://sandbox.ibedc.com/api
DISCO_IBEDC_API_KEY=your_ibedc_api_key

DISCO_EKEDC_API_URL=https://sandbox.ekedc.com/api
DISCO_EKEDC_API_KEY=your_ekedc_api_key

DISCO_AEDC_API_URL=https://sandbox.aedc.com/api
DISCO_AEDC_API_KEY=your_aedc_api_key

# ── Firebase (Push Notifications) ──────────────
FIREBASE_CREDENTIALS_PATH=config/firebase_credentials.json

# ── SMS Gateway ─────────────────────────────────
SMS_GATEWAY_URL=https://api.your-sms-gateway.com
SMS_GATEWAY_API_KEY=your_sms_gateway_api_key
SMS_SENDER_ID=ETIP

# ── AWS S3 (File Storage — receipts, exports) ──
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=etip-media
AWS_S3_REGION_NAME=eu-west-1

# ── Encryption ──────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# ── Frontend URLs ───────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001

# ── Email (optional — for admin notifications) ─
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
